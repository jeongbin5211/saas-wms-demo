# ── 데이터베이스 ──
DB_URL=jdbc:mysql://your-rds-endpoint:3306/withworks_demo?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=wms_user
DB_PASSWORD=your-secure-password

# ── JWT ──
JWT_SECRET=your-256bit-minimum-secret-key-change-this-in-production
JWT_EXPIRATION_HOURS=8

# ── 서버 ──
SERVER_PORT=8080

# ── CORS ──
CORS_ALLOWED_ORIGINS=https://your-cloudfront-domain.cloudfront.net

# ── Spring 프로파일 ──
SPRING_PROFILES_ACTIVE=prod
